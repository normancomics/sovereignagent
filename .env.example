# Example .env for sovereignagent (DO NOT commit real secrets)
# Copy this file to .env and fill in all values before running any scripts.

# ── Wallet / Blockchain ──────────────────────────────────────────────────────
# Private key of the agent wallet used to sign on-chain transactions.
PRIVATE_KEY=your_wallet_private_key_here

# Base mainnet RPC endpoint. Use Alchemy or Infura for reliability.
# Public fallback: https://mainnet.base.org
# Alchemy: https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
RPC_URL=https://mainnet.base.org

# Must be 8453 for Base mainnet (was 84531 for deprecated Base Goerli testnet).
CHAIN_ID=8453

# Superfluid super-token symbol on Base mainnet.
# USDCx address on Base: 0xD04383398dD2426297da660F9CCA3d439AF9ce1b
SUPER_TOKEN=USDCx

# The wallet address that will receive Superfluid payment streams.
# Typically the same address derived from PRIVATE_KEY above.
SOVEREIGN_AGENT_ADDRESS=0xYourAgentWalletAddress

# Superfluid flow rate in wei/second.
# 385802469135802 ≈ $1/day in USDCx (6 decimals: 1e6 / 86400 * 1e12)
FLOW_RATE=385802469135802

# ── Registry Contracts (Base mainnet) ────────────────────────────────────────
IDENTITY_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
REPUTATION_REGISTRY_ADDRESS=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63

# ── Agent Metadata ───────────────────────────────────────────────────────────
# Public URL (or IPFS CID) of your agent-manifest.json file.
# This URI is stored on-chain in the Identity Registry.
# Example using the GitHub raw URL:
# AGENT_METADATA_URI=https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/agent-manifest.json
AGENT_METADATA_URI=https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/agent-manifest.json

# ── CryptoSkill (https://cryptoskill.org) ────────────────────────────────────
# Get your API key by signing up at https://cryptoskill.org
CRYPTOSKILL_API_KEY=your_cryptoskill_api_key_here

# ── x402 Payment Server ──────────────────────────────────────────────────────
# Port to run the agent HTTP server on (default: 3000)
PORT=3000

# Address that receives x402 payments (usually same as SOVEREIGN_AGENT_ADDRESS)
PAYMENT_RECEIVER_ADDRESS=0xYourAgentWalletAddress

# USDCx token address on Base mainnet (do not change unless using a different token)
PAYMENT_TOKEN_ADDRESS=0xD04383398dD2426297da660F9CCA3d439AF9ce1b

# Public URL where your server.js is accessible (needed for CDP Bazaar listing)
# Use ngrok for local testing: https://ngrok.com
# Example: AGENT_SERVER_URL=https://abc123.ngrok.io
AGENT_SERVER_URL=https://your-public-domain.com

# ── Coinbase CDP (https://portal.cdp.coinbase.com) ───────────────────────────
# Required for listing on the CDP x402 Bazaar (scripts/list-on-bazaar.js)
CDP_API_KEY_NAME=your_cdp_api_key_name
CDP_API_KEY_PRIVATE_KEY=your_cdp_api_key_private_key

# ── HaveIBeenPwned (https://haveibeenpwned.com/API/Key) ──────────────────────
# Required for the breach-check skill's email lookup.
# Password check uses k-anonymity and does NOT require this key.
HIBP_API_KEY=your_hibp_api_key_here

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per IP per minute for GET /manifest and GET /health (default: 60)
RATE_LIMIT_PUBLIC=60
# Max requests per IP per minute for POST /skills/* endpoints (default: 20)
RATE_LIMIT_PAID=20
# Maximum allowed request body size in bytes (default: 65536 = 64 KB)
MAX_BODY_BYTES=65536

# ── Test / Local Dev ──────────────────────────────────────────────────────────
# Address to use as receiver in test.js Superfluid demo (optional)
TEST_RECEIVER_ADDRESS=0x3d95d4a6dbae0cd0643a82b13a13b08921d6adf7
TEST_FLOW_RATE=1000000000000

# ── Solana ────────────────────────────────────────────────────────────────────
# Cluster to connect to: devnet | testnet | mainnet-beta (default: devnet)
SOLANA_CLUSTER=devnet

# Absolute path to the Solana keypair JSON file used for deployment and signing.
# Generate one with: solana-keygen new --outfile ~/.config/solana/id.json
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# Program ID of the deployed PhantomOperator Solana program.
# Populated automatically by solana/scripts/deploy.sh after a successful deploy.
SOLANA_PROGRAM_ID=

# (Optional) Custom RPC endpoint for mainnet-beta.
# Recommended: use a private RPC from Alchemy, QuickNode, or Triton for reliability.
# Leave empty to use the public Solana cluster endpoint.
SOLANA_RPC_URL=

# Notes:
# - Never commit .env to source control (.gitignore already excludes it).
# - For GitHub Actions CI, add all the above as repository secrets.
